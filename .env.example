# Environment variable NAMES for the image-search system.
# Copy to `.env` and fill real values. NEVER commit real secrets.
# The repo-root `.env` is consumed by infra/docker-compose.yml (ml-service).
# Worker secrets are set separately via `wrangler secret put <NAME>`.

# ---- ml-service: encoder / vectors ----
ENCODER=siglip2                 # siglip2 (default, Apache-2.0) | dinov3 (gated)
EMBEDDING_DIM=                  # optional; defaults to encoder native dim
ACTIVE_COLLECTION=              # optional; defaults to image_embeddings_{encoder}_{dim}
DEVICE=cuda
BATCH_SIZE=32

# ---- ml-service: Qdrant ----
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=                 # optional

# ---- ml-service: auth (Worker -> service) ----
ML_SERVICE_SHARED_SECRET=       # shared secret / HMAC signing key

# ---- ml-service: D1 REST (INDEXING ENVIRONMENT ONLY — not the Worker) ----
D1_ACCOUNT_ID=
D1_DATABASE_ID=
D1_API_TOKEN=

# ---- Worker vars/secrets (set via `wrangler secret put`, listed here by NAME) ----
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
ML_SERVICE_URL=http://localhost:8000
TEXT_SEARCH_URL=
TEXT_SEARCH_AUTH=
COMMERCE_API_URL=
COMMERCE_API_AUTH=
IMAGE_SEARCH_ENABLED=false
HYBRID_FUSION_ENABLED=false
